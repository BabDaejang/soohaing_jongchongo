# Supabase 프로젝트 (대시보드 → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service role — 서버 전용. 클라이언트에 노출 금지 (INV-4)
SUPABASE_SERVICE_ROLE_KEY=

# API 키 암호화용 32바이트 랜덤 (base64). 예: openssl rand -base64 32
APP_ENCRYPTION_KEY=

# 최초 관리자로 승격할 Google 계정 이메일 (첫 로그인 시 admin·approved 자동 승격)
ADMIN_EMAIL=

# 원본 자동 삭제 Cron 라우트 보호용 시크릿 (세션 6). 스케줄러가 Authorization: Bearer <값>로 호출.
# 예: openssl rand -hex 32. 미설정 시 /api/cron/purge-originals는 비활성(503).
# Vercel Cron은 CRON_SECRET 환경변수가 있으면 이 값을 Bearer로 자동 첨부한다(vercel.json crons).
CRON_SECRET=

# 마이그레이션 적용용 DB 직접 연결 (Supabase 대시보드 → Settings → Database → Connection string).
# 앱 런타임은 사용하지 않고 `supabase db push --db-url`(CLI)에서만 쓴다. 절대 커밋 금지.
# 직접 호스트가 IPv6 전용이라 라우팅이 안 되면 동일 비밀번호로 IPv4 pooler(세션 모드)를 쓴다:
#   postgresql://postgres.<ref>:<pw>@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres
SUPABASE_DB_URL=

# 참고: Google OAuth 클라이언트 ID/시크릿은 앱 환경변수가 아니라
#   Supabase 대시보드 → Authentication → Providers → Google 에 등록한다(리다이렉트 URL 포함).
